rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    function isVerifiedRealtor() {
      return request.auth != null
        && request.auth.token.role == 'realtor'
        && request.auth.token.verified == true;
    }
    function isAdmin() {
      return request.auth != null && request.auth.token.admin == true;
    }

    // Event photos — verified realtors upload to their event paths.
    // Allow only web-displayable photo formats up to 10MB. Client validates
    // first and shows a friendly Hebrew message; this rule is the security
    // backstop.
    function isAllowedPhotoUpload() {
      return (request.resource.contentType == 'image/jpeg'
        || request.resource.contentType == 'image/png'
        || request.resource.contentType == 'image/heic'
        || request.resource.contentType == 'image/heif'
        || request.resource.contentType == 'image/webp')
        && !fileName.matches('.*\\.(dng|DNG|raw|RAW|cr2|CR2|nef|NEF|arw|ARW)');
    }
    match /events/{eventId}/{fileName} {
      allow read: if true; // public read for map popups, OG images
      allow write: if (isVerifiedRealtor() || isAdmin())
        && request.resource.size < 10 * 1024 * 1024 // 10MB
        && isAllowedPhotoUpload();
      allow delete: if isVerifiedRealtor() || isAdmin();
    }

    // User avatars (future)
    match /users/{userId}/avatar/{fileName} {
      allow read: if true;
      allow write: if request.auth != null
        && request.auth.uid == userId
        && request.resource.size < 2 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }

    // Default deny
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
