rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    function isVerifiedRealtor() {
      return request.auth != null
        && request.auth.token.role == 'realtor'
        && request.auth.token.verified == true;
    }
    function isAdmin() {
      return request.auth != null && request.auth.token.admin == true;
    }

    // Event photos — verified realtors upload to their event paths.
    // Allow only web-displayable photo formats up to 10MB.
    // MIME check is in a function (no path vars), filename extension check
    // stays inline in the match block where `fileName` is actually bound.
    // Previously this function tried to read `fileName` and silently
    // returned undefined (out-of-scope), which Firebase emits as a
    // compiler warning and made the rule unstable.
    function isAllowedPhotoMime() {
      return request.resource.contentType == 'image/jpeg'
        || request.resource.contentType == 'image/png'
        || request.resource.contentType == 'image/heic'
        || request.resource.contentType == 'image/heif'
        || request.resource.contentType == 'image/webp';
    }
    match /events/{eventId}/{fileName} {
      allow read: if true; // public read for map popups, OG images
      allow write: if (isVerifiedRealtor() || isAdmin())
        && request.resource.size < 10 * 1024 * 1024 // 10MB
        && isAllowedPhotoMime()
        && !fileName.matches('.*\\.(dng|DNG|raw|RAW|cr2|CR2|nef|NEF|arw|ARW)');
      // Delete only by admin. Per-realtor scope-check is impossible from
      // Storage rules alone (eventId ≠ uid). Realtors who need to remove
      // photos on their own event should route through a Cloud Function
      // that verifies Firestore ownership first. Closes a hole where any
      // verified realtor could deleteObject() on /events/<otherRealtorId>/.
      allow delete: if isAdmin();
    }

    // User avatars (future)
    match /users/{userId}/avatar/{fileName} {
      allow read: if true;
      allow write: if request.auth != null
        && request.auth.uid == userId
        && request.resource.size < 2 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }

    // Office logo — verified realtor uploads firm logo. Used in event popup,
    // detail page realtor block, and share cards. SVG accepted since logos
    // are commonly vector.
    match /users/{userId}/logo/{fileName} {
      allow read: if true;
      allow write: if request.auth != null
        && request.auth.uid == userId
        && request.resource.size < 2 * 1024 * 1024
        && (request.resource.contentType == 'image/jpeg'
            || request.resource.contentType == 'image/png'
            || request.resource.contentType == 'image/webp'
            || request.resource.contentType == 'image/svg+xml');
      allow delete: if request.auth != null && request.auth.uid == userId;
    }

    // Default deny
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
